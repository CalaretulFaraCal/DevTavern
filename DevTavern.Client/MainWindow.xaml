                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                                Click="CancelAddVoiceChannel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CancelBg" CornerRadius="6" Background="Transparent"
                                            BorderBrush="#30363D" BorderThickness="1" Padding="16,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CancelBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="#8B949E"/>
                            </Button.Foreground>
                        </Button>
                        <Button Content="Create" Padding="16,8" Cursor="Hand"
                                Click="ConfirmAddVoiceChannel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CreateBg" CornerRadius="6" Padding="16,8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#238636" Offset="0"/>
                                                <GradientStop Color="#2EA043" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CreateBg" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== VOICE SETTINGS OVERLAY ========== -->
        <Grid x:Name="VoiceSettingsOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#80000000" MouseDown="VoiceSettingsOverlay_MouseDown"/>
            <Border Width="520" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="680">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="24,20,24,16" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Voice Settings" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3"/>
                                <TextBlock Text="Configure audio for voice channels" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Click="CloseVoiceSettings_Click" Cursor="Hand"
                                    Width="28" Height="28" VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBg" CornerRadius="6" Background="Transparent">
                                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                                  Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBg" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Scrollable content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
                        <StackPanel>

                            <!-- ─── DEVICES ─── -->
                            <TextBlock Text="DEVICES" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#8B949E" Margin="0,20,0,10"/>

                            <TextBlock Text="Input Device (microphone)" FontSize="12"
                                       Foreground="#8B949E" Margin="0,0,0,6"/>
                            <ComboBox x:Name="InputDeviceCombo" Style="{StaticResource DarkComboBox}" Margin="0,0,0,14"/>

                            <TextBlock Text="Output Device (speakers)" FontSize="12"
                                       Foreground="#8B949E" Margin="0,0,0,6"/>
                            <ComboBox x:Name="OutputDeviceCombo" Style="{StaticResource DarkComboBox}"/>

                            <!-- ─── VOLUME ─── -->
                            <Border Height="1" Background="#21262D" Margin="0,20,0,0"/>
                            <TextBlock Text="VOLUME" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#8B949E" Margin="0,16,0,10"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Input Volume" FontSize="12" Foreground="#8B949E" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" FontSize="12" Foreground="#E6EDF3" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Text="{Binding Value, ElementName=InputVolumeSlider, StringFormat={}{0:F0}%}"/>
                            </Grid>
                            <Slider x:Name="InputVolumeSlider" Style="{StaticResource VoiceSlider}"
                                    Minimum="0" Maximum="200" Value="100" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Output Volume" FontSize="12" Foreground="#8B949E" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" FontSize="12" Foreground="#E6EDF3" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Text="{Binding Value, ElementName=OutputVolumeSlider, StringFormat={}{0:F0}%}"/>
                            </Grid>
                            <Slider x:Name="OutputVolumeSlider" Style="{StaticResource VoiceSlider}"
                                    Minimum="0" Maximum="200" Value="100"/>

                            <!-- ─── VOICE DETECTION ─── -->
                            <Border Height="1" Background="#21262D" Margin="0,20,0,0"/>
                            <TextBlock Text="VOICE DETECTION" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#8B949E" Margin="0,16,0,12"/>

                            <RadioButton x:Name="VadModeRadio" Content="Voice Activity (VAD)"
                                         GroupName="VoiceMode" IsChecked="True"
                                         Style="{StaticResource VoiceRadioStyle}"
                                         Checked="VadMode_Checked" Margin="0,0,0,10"/>
                            <RadioButton x:Name="PttModeRadio" Content="Push to Talk (PTT)"
                                         GroupName="VoiceMode"
                                         Style="{StaticResource VoiceRadioStyle}"
                                         Checked="PttMode_Checked"/>

                            <!-- Sensitivity (VAD only) -->
                            <StackPanel x:Name="SensitivityPanel" Margin="0,14,0,0">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Input Sensitivity" FontSize="12" Foreground="#8B949E" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="#E6EDF3" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{Binding Value, ElementName=SensitivitySlider, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Slider x:Name="SensitivitySlider" Style="{StaticResource VoiceSlider}"
                                        Minimum="0" Maximum="100" Value="50"/>
                                <TextBlock Text="Your voice will automatically activate the microphone above the set threshold."
                                           FontSize="11" Foreground="#8B949E" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- PTT key/button (PTT only) -->
                            <StackPanel x:Name="PttKeyPanel" Visibility="Collapsed" Margin="0,14,0,0">
                                <TextBlock Text="Push to Talk shortcut" FontSize="12"
                                           Foreground="#8B949E" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#0D1117" BorderBrush="#30363D"
                                            BorderThickness="1" CornerRadius="6" Padding="12,8">
                                        <TextBlock x:Name="PttKeyDisplay" Text="Caps Lock"
                                                   Foreground="#E6EDF3" FontSize="13"/>
                                    </Border>
                                    <Button x:Name="PttKeyButton" Grid.Column="1" Content="Change"
                                            Margin="8,0,0,0" Cursor="Hand" Click="PttKeyButton_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="PttBg" CornerRadius="6" BorderBrush="#30363D"
                                                        BorderThickness="1" Padding="14,8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="PttBg" Property="Background" Value="#1C2333"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Foreground>
                                            <SolidColorBrush Color="#8B949E"/>
                                        </Button.Foreground>
                                    </Button>
                                </Grid>
                                <TextBlock x:Name="PttCaptureHint" Visibility="Collapsed"
                                           Text="Press any key or mouse button to assign... (Esc to cancel)"
                                           FontSize="11" Foreground="#3FB950" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== CHANNEL SETTINGS OVERLAY ========== -->
        <Grid x:Name="ChannelSettingsOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed">
            <!-- Dark backdrop -->
            <Border Background="#80000000" MouseDown="ChannelSettingsOverlay_MouseDown"/>

            <!-- Settings dialog -->
            <Border Width="480" MinHeight="340" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="Auto"/>  <!-- Tab bar -->
                        <RowDefinition Height="*"/>     <!-- Tab content -->
                        <RowDefinition Height="Auto"/>  <!-- Footer / danger zone -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="24,18,24,14" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="#" FontSize="18" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SettingsChannelTitle" Text="general" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Channel Settings" FontSize="12" Foreground="#8B949E" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Close button -->
                            <Button Grid.Column="1" Cursor="Hand" Click="CloseChannelSettings_Click" ToolTip="Close" VerticalAlignment="Top">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBg" CornerRadius="6" Background="Transparent" Width="28" Height="28">
                                            <Path Data="M18,6 L6,18 M6,6 L18,18" Stroke="#8B949E" StrokeThickness="1.5"
                                                  Stretch="Uniform" Width="12" Height="12"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBg" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Tab bar -->
                    <Border Grid.Row="1" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="24,0,24,0">
                            <!-- Overview Tab -->
                            <Button x:Name="TabOverviewBtn" Cursor="Hand" Click="TabOverview_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBg" Padding="12,10" Background="Transparent"
                                                BorderBrush="#238636" BorderThickness="0,0,0,2">
                                            <TextBlock Text="Overview" FontSize="13" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Permissions Tab -->
                            <Button x:Name="TabPermissionsBtn" Cursor="Hand" Click="TabPermissions_Click" Margin="4,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBg" Padding="12,10" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                            <TextBlock x:Name="TabText" Text="Permissions" FontSize="13" Foreground="#8B949E"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#E6EDF3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Tab Content -->
                    <Grid Grid.Row="2" Margin="24,16,24,16">
                        <!-- Overview Tab Content -->
                        <StackPanel x:Name="OverviewTabContent" Visibility="Visible">
                            <TextBlock Text="CHANNEL NAME" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,8"/>
                            <Border CornerRadius="6" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" Padding="2">
                                <TextBox x:Name="EditChannelNameInput" Background="Transparent" BorderThickness="0"
                                         Foreground="#E6EDF3" FontSize="14" Padding="10,8"
                                         VerticalContentAlignment="Center">
                                    <TextBox.CaretBrush>
                                        <SolidColorBrush Color="#E6EDF3"/>
                                    </TextBox.CaretBrush>
                                </TextBox>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Save Changes" Padding="16,8" Cursor="Hand"
                                        Click="SaveChannelName_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="SaveBg" CornerRadius="6" Padding="16,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#238636" Offset="0"/>
                                                        <GradientStop Color="#2EA043" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="SaveBg" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground>
                                        <SolidColorBrush Color="White"/>
                                    </Button.Foreground>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Permissions Tab Content -->
                        <StackPanel x:Name="PermissionsTabContent" Visibility="Collapsed">
                            <Border Background="#0D1117" CornerRadius="8" Padding="20,24" Margin="0,0,0,8">
                                <StackPanel HorizontalAlignment="Center">
                                    <!-- Lock icon as vector Path -->
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#1C2333" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <Path Data="M12,17A2,2 0 0,0 14,15A2,2 0 0,0 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10A2,2 0 0,1 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                              Fill="#8B949E" Stretch="Uniform" Width="20" Height="20"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Permissions coming soon" FontSize="15" FontWeight="SemiBold" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Channel permission management will be available in a future update." FontSize="12" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Danger Zone (Delete) -->
                    <Border Grid.Row="3" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="24,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Danger Zone" FontSize="13" FontWeight="SemiBold" Foreground="#F85149"/>
                                <TextBlock Text="Permanently delete this channel and all its messages" FontSize="11" Foreground="#8B949E" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Delete Channel" Padding="14,7" Cursor="Hand"
                                    Click="DeleteChannel_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DelBg" CornerRadius="6" Padding="14,7"
                                                Background="Transparent" BorderBrush="#F85149" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DelBg" Property="Background" Value="#F85149"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Foreground>
                                    <SolidColorBrush Color="#F85149"/>
                                </Button.Foreground>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== DELETE CONFIRMATION OVERLAY ========== -->
        <Grid x:Name="DeleteConfirmOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#AA000000" MouseDown="DeleteConfirmOverlay_BackdropClick"/>

            <Border Width="420" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Padding="24,20">
                <StackPanel>
                    <!-- Warning icon -->
                    <Border Width="48" Height="48" CornerRadius="24" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <SolidColorBrush Color="#F85149" Opacity="0.15"/>
                        </Border.Background>
                        <Path Data="M12,2 L1,21 L23,21 Z M12,9 L12,15 M12,17 L12,19"
                              Stroke="#F85149" StrokeThickness="1.8" Fill="Transparent"
                              Stretch="Uniform" Width="24" Height="24"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Delete Channel" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DeleteConfirmMessage" TextWrapping="Wrap" TextAlignment="Center"
                               FontSize="13" Foreground="#8B949E" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Cancel" Padding="20,9" Margin="0,0,10,0" Cursor="Hand"
                                Click="DeleteConfirmCancel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CancelBg" CornerRadius="6" Background="Transparent"
                                            BorderBrush="#30363D" BorderThickness="1" Padding="20,9">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CancelBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="#8B949E"/>
                            </Button.Foreground>
                        </Button>
                        <Button Content="Delete" Padding="20,9" Cursor="Hand"
                                Click="DeleteConfirmYes_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="DelBg" CornerRadius="6" Padding="20,9"
                                            Background="#F85149">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DelBg" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========== SET ROLES OVERLAY ========== -->
        <Grid x:Name="RoleSelectionOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="#80000000" MouseDown="RoleSelectionOverlay_BackdropClick"/>
            <Border Width="300" Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="Set Your Roles" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3" Margin="0,0,0,4"/>
                    <TextBlock Text="Select the developer roles you fulfill on this project." FontSize="12" Foreground="#8B949E" Margin="0,0,0,16" TextWrapping="Wrap"/>

                    <StackPanel x:Name="RoleCheckboxesContainer" Margin="0,0,0,20">
                        <CheckBox Content="Frontend Developer" Foreground="#E6EDF3" Margin="0,4"/>
                        <CheckBox Content="Backend Developer" Foreground="#E6EDF3" Margin="0,4"/>
                        <CheckBox Content="Fullstack Developer" Foreground="#E6EDF3" Margin="0,4"/>
                        <CheckBox Content="QA / Tester" Foreground="#E6EDF3" Margin="0,4"/>
                        <CheckBox Content="UI/UX Designer" Foreground="#E6EDF3" Margin="0,4"/>
                        <CheckBox Content="DevOps" Foreground="#E6EDF3" Margin="0,4"/>
                        <CheckBox Content="Project Manager" Foreground="#E6EDF3" Margin="0,4"/>
                    </StackPanel>

                    <Button Content="Save Roles" Height="36" Background="#238636" Foreground="White" 
                            BorderThickness="0" Cursor="Hand" Click="SaveRoles_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="6" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========== IMPORT PROJECTS OVERLAY ========== -->
        <Grid x:Name="ImportProjectsOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#80000000" MouseDown="ImportProjectsOverlay_BackdropClick"/>

            <Border Width="400" MaxHeight="500" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Padding="24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Import GitHub Projects" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3"/>
                        <TextBlock x:Name="ImportStatusText" Text="Loading repositories..." FontSize="13" Foreground="#8B949E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- ListBox with Checkboxes -->
                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1" BorderBrush="#30363D" Background="#0D1117">
                        <ListBox x:Name="ImportProjectsList" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="4">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Content="{Binding name}" IsChecked="{Binding isSelected}"
                                                  Foreground="#E6EDF3" FontSize="14" VerticalContentAlignment="Center" Cursor="Hand"/>
                                        <TextBlock Grid.Column="1" Text="{Binding VisibilityLabel}" FontSize="11" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Select All" Background="Transparent" Foreground="#8B949E" BorderThickness="0" Cursor="Hand" Click="ImportSelectAll_Click"/>
                        
                        <Button Grid.Column="2" Content="Import Selected" Padding="16,8" Cursor="Hand" Click="ConfirmImport_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ImportBtnBg" CornerRadius="6" Background="#238636" Padding="16,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ImportBtnBg" Property="Background" Value="#2EA043"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="ImportBtnBg" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
