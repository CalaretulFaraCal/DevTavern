<Window x:Class="DevTavern.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevTavern" Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <!-- Color Palette -->
        <Color x:Key="BgDark">#0D1117</Color>
        <Color x:Key="BgCard">#161B22</Color>
        <Color x:Key="BgCardHover">#1C2333</Color>
        <Color x:Key="AccentGreen">#238636</Color>
        <Color x:Key="AccentGreenHover">#2EA043</Color>
        <Color x:Key="AccentPurple">#8B5CF6</Color>
        <Color x:Key="TextPrimary">#E6EDF3</Color>
        <Color x:Key="TextSecondary">#8B949E</Color>
        <Color x:Key="BorderSubtle">#30363D</Color>

        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>

        <!-- GitHub Login Button Style -->
        <Style x:Key="GitHubLoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="12" Padding="20,0"
                                Background="{TemplateBinding Background}"
                                BorderThickness="1" BorderBrush="#30363D">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2EA043" Offset="0"/>
                                            <GradientStop Color="#238636" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#238636" BlurRadius="30" ShadowDepth="2" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Style (Select All, Deselect, Import) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder" CornerRadius="8" Padding="16,0"
                                Background="{TemplateBinding Background}"
                                BorderThickness="1" BorderBrush="#30363D">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter TargetName="ActionBorder" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1C2333"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ActionBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Import Button Style (Green accent) -->
        <Style x:Key="ImportButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ImportBorder" CornerRadius="8" Padding="20,0"
                                BorderThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#238636" Offset="0"/>
                                    <GradientStop Color="#2EA043" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#238636" BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ImportBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2EA043" Offset="0"/>
                                            <GradientStop Color="#3FB950" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ImportBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#238636" BlurRadius="25" ShadowDepth="2" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ImportBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ImportBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Style for Repo Items -->
        <Style x:Key="RepoCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CbBorder" Background="Transparent" CornerRadius="8"
                                Padding="12,10" BorderThickness="1" BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="CheckBorder" Width="20" Height="20" CornerRadius="5"
                                        BorderThickness="2" BorderBrush="#30363D" Background="Transparent"
                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Path x:Name="CheckMark" Data="M 3 10 L 8 15 L 17 4"
                                          Stroke="#238636" StrokeThickness="2"
                                          Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#238636"/>
                                <Setter TargetName="CheckBorder" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#238636" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CbBorder" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1C2333"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="CbBorder" Property="BorderBrush" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox Style -->
        <Style x:Key="RepoListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Storyboard for fade-in -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- Main Background with Gradient -->
    <Border CornerRadius="16" MouseLeftButtonDown="DragWindow">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="0.5"/>
                <GradientStop Color="#0D1117" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Decorative circles (subtle glow effects) -->
            <Ellipse Width="300" Height="300" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-100,0" Opacity="0.07">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B5CF6" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="250" Height="250" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-80,0,0,-80" Opacity="0.05">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#238636" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid Margin="32,12,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Title bar -->
                    <RowDefinition Height="Auto"/>   <!-- Header/Logo -->
                    <RowDefinition Height="Auto"/>   <!-- Login button -->
                    <RowDefinition Height="Auto"/>   <!-- Status -->
                    <RowDefinition Height="*"/>      <!-- Repos list -->
                    <RowDefinition Height="Auto"/>   <!-- Action buttons -->
                </Grid.RowDefinitions>

                <!-- Custom Title Bar -->
                <Grid Grid.Row="0" Margin="-16,0,-20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="DevTavern" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0">
                        <Button Content="─" FontSize="14" Width="40" Height="30"
                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0" Cursor="Hand" Click="MinimizeButton_Click"
                                VerticalContentAlignment="Center"/>
                        <Button Content="✕" FontSize="12" Width="40" Height="30"
                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Logo & Welcome Section -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,30">
                    <!-- GitHub-style Logo Circle -->
                    <Border Width="80" Height="80" CornerRadius="40" HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#238636" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#8B5CF6" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                        </Border.Effect>
                        <!-- GitHub Octocat Path -->
                        <Path Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                              Fill="White" Width="36" Height="36" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Welcome!" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sign in with GitHub"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <!-- Login Button -->
                <Button x:Name="LoginButton" Grid.Row="2"
                        Style="{StaticResource GitHubLoginButtonStyle}"
                        Click="LoginButton_Click"
                        Margin="30,0,30,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#238636" Offset="0"/>
                            <GradientStop Color="#2EA043" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                              Fill="White" Width="18" Height="18" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Login with GitHub" VerticalAlignment="Center"
                                   FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Status Text -->
                <Border Grid.Row="3" Margin="0,20,0,10" Padding="16,10" CornerRadius="8"
                        Background="Transparent">
                    <TextBlock x:Name="StatusText" Text="Not logged in."
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Border>

                <!-- Repos List (shown after login) -->
                <Border Grid.Row="4" CornerRadius="12" Margin="0,0,0,10"
                        BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                        Visibility="Collapsed" x:Name="ReposContainer">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource BgCard}" Opacity="0.6"/>
                    </Border.Background>
                    <ListBox x:Name="ReposList" Style="{StaticResource RepoListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Content="{Binding name}" IsChecked="{Binding isSelected}"
                                              Style="{StaticResource RepoCheckBoxStyle}"/>
                                    <!-- Public/Private Badge -->
                                    <Border Grid.Column="1" CornerRadius="10" Padding="10,4" Margin="0,0,12,0"
                                            VerticalAlignment="Center" HorizontalAlignment="Right"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#30363D"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding isPrivate}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#DA3633"/>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#DA3633" Opacity="0.12"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding isPrivate}" Value="False">
                                                        <Setter Property="BorderBrush" Value="#238636"/>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#238636" Opacity="0.12"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Lock icon for private, globe for public -->
                                            <Path VerticalAlignment="Center" Margin="0,0,5,0" Width="11" Height="11" Stretch="Uniform">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding isPrivate}" Value="True">
                                                                <Setter Property="Data" Value="M6 0C3.79 0 2 1.79 2 4v2H1a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H10V4c0-2.21-1.79-4-4-4zm2 6H4V4c0-1.1.9-2 2-2s2 .9 2 2v2z"/>
                                                                <Setter Property="Fill" Value="#DA3633"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding isPrivate}" Value="False">
                                                                <Setter Property="Data" Value="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zM5.78 1.98a6 6 0 0 0-3.73 3.2h2.64c.14-.94.36-1.8.65-2.54.14-.36.3-.68.44-.66zM1.5 8c0 .62.1 1.22.27 1.78h3.15a20 20 0 0 1 0-3.56H1.77A6.5 6.5 0 0 0 1.5 8zm.55 3.28a6 6 0 0 0 3.73 3.2c-.14.02-.3-.3-.44-.66-.29-.74-.51-1.6-.65-2.54H2.05zm5.2 3.7a6 6 0 0 0 .5 0c.44-.06 1.15-.98 1.6-2.36.17-.5.31-1.07.42-1.66H6.23c.11.59.25 1.16.42 1.66.45 1.38 1.16 2.3 1.6 2.36zM6.08 9.78a18 18 0 0 0 0-3.56h3.84a18 18 0 0 0 0 3.56H6.08zm4.34 1.5c-.14.94-.36 1.8-.65 2.54-.14.36-.3.68-.44.66a6 6 0 0 0 3.73-3.2h-2.64zm3.31-3.06a6.5 6.5 0 0 0 0-1.44h-3.15a20 20 0 0 1 0 3.56h3.15c.17-.56.27-1.16.27-1.78 0-.24-.02-.48-.04-.7.03-.22.04-.44.04-.64zm-3.96-3a18 18 0 0 0-.42-1.66c-.45-1.38-1.16-2.3-1.6-2.36a6 6 0 0 0-.5 0c-.44.06-1.15.98-1.6 2.36-.17.5-.31 1.07-.42 1.66h3.84z"/>
                                                                <Setter Property="Fill" Value="#238636"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                            <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding isPrivate}" Value="True">
                                                                <Setter Property="Text" Value="Private"/>
                                                                <Setter Property="Foreground" Value="#DA3633"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding isPrivate}" Value="False">
                                                                <Setter Property="Text" Value="Public"/>
                                                                <Setter Property="Foreground" Value="#238636"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <!-- Action Buttons (shown after login) -->
                <StackPanel x:Name="ActionButtons" Grid.Row="5" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,5,0,10" Visibility="Collapsed">
                    <Button Content="Select All" Width="100" Margin="5"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="SelectAll_Click">
                        <Button.Background>
                            <SolidColorBrush Color="{StaticResource BgCard}"/>
                        </Button.Background>
                    </Button>
                    <Button Content="Deselect All" Width="110" Margin="5"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="DeselectAll_Click">
                        <Button.Background>
                            <SolidColorBrush Color="{StaticResource BgCard}"/>
                        </Button.Background>
                    </Button>
                    <Button Content="🚀 Import" Width="130" Height="40" Margin="5"
                            Style="{StaticResource ImportButtonStyle}"
                            FontWeight="Bold" FontSize="14"
                            Click="ImportButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
