        <!-- ========== ADD CHANNEL POPUP OVERLAY ========== -->
        <Grid x:Name="AddChannelOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed">
            <!-- Dark backdrop -->
            <Border Background="#80000000" MouseDown="AddChannelOverlay_MouseDown"/>

            <!-- Popup dialog -->
            <Border Width="400" Height="200" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Create Channel" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Enter a name for the new channel" FontSize="12"
                               Foreground="#8B949E" Margin="0,0,0,16"/>

                    <Border Grid.Row="2" CornerRadius="6" Background="#0D1117" BorderBrush="#30363D"
                            BorderThickness="1" Padding="2" VerticalAlignment="Center">
                        <TextBox x:Name="NewChannelNameInput" Background="Transparent" BorderThickness="0"
                                 Foreground="#E6EDF3" FontSize="14" Padding="10,8"
                                 VerticalContentAlignment="Center"
                                 KeyDown="NewChannelNameInput_KeyDown">
                            <TextBox.CaretBrush>
                                <SolidColorBrush Color="#E6EDF3"/>
                            </TextBox.CaretBrush>
                        </TextBox>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                                Click="CancelAddChannel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CancelBg" CornerRadius="6" Background="Transparent"
                                            BorderBrush="#30363D" BorderThickness="1" Padding="16,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CancelBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="#8B949E"/>
                            </Button.Foreground>
                        </Button>
                        <Button Content="Create" Padding="16,8" Cursor="Hand"
                                Click="ConfirmAddChannel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CreateBg" CornerRadius="6" Padding="16,8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#238636" Offset="0"/>
                                                <GradientStop Color="#2EA043" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CreateBg" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== ADD VOICE CHANNEL POPUP OVERLAY ========== -->
        <Grid x:Name="AddVoiceChannelOverlay" Grid.ColumnSpan="5" Grid.RowSpan="2" Visibility="Collapsed">
            <!-- Dark backdrop -->
            <Border Background="#80000000" MouseDown="AddVoiceChannelOverlay_MouseDown"/>

            <!-- Popup dialog -->
            <Border Width="400" Height="200" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Create Voice Channel" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Enter a name for the new voice channel" FontSize="12"
                               Foreground="#8B949E" Margin="0,0,0,16"/>

                    <Border Grid.Row="2" CornerRadius="6" Background="#0D1117" BorderBrush="#30363D"
                            BorderThickness="1" Padding="2" VerticalAlignment="Center">
                        <TextBox x:Name="NewVoiceChannelNameInput" Background="Transparent" BorderThickness="0"
                                 Foreground="#E6EDF3" FontSize="14" Padding="10,8"
