<Window x:Class="DevTavern.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevTavern" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Tooltip style with arrow indicator -->
        <Style x:Key="ProjectTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#1C2333"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="HorizontalOffset" Value="14"/>
            <Setter Property="HasDropShadow" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Arrow pointing left toward icon -->
                            <Path Grid.Column="0" Data="M 8,0 L 0,8 L 8,16" Fill="#1C2333" Stroke="#30363D"
                                  StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,-1,0"/>
                            <Border Grid.Column="1" Background="#1C2333" BorderBrush="#30363D" BorderThickness="1"
                                    CornerRadius="6" Padding="10,6">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                                </Border.Effect>
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Channel list item style -->
        <Style x:Key="ChannelItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBg" CornerRadius="4" Padding="8,6" Background="Transparent" Margin="4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" HorizontalAlignment="Stretch"/>
                                <!-- Gear icon — part of the ListBoxItem template so IsMouseOver works on the whole row -->
                                <Button x:Name="GearBtn" Grid.Column="1" Cursor="Hand"
                                        Click="ChannelSettingsBtn_Click"
                                        ToolTip="Channel Settings"
                                        Visibility="Hidden">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="GearBg" CornerRadius="4" Background="Transparent"
                                                    Width="22" Height="22">
                                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                                      Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="GearBg" Property="Background" Value="#30363D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                <Setter TargetName="GearBtn" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                <Setter TargetName="ItemBg" Property="BorderBrush" Value="#30363D"/>
                                <Setter TargetName="ItemBg" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Members list item style -->
        <Style x:Key="MemberItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border CornerRadius="4" Padding="8,6" Background="Transparent" Margin="4,0">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Project icon sidebar -->
            <ColumnDefinition Width="72"/>
            <!-- Channel list -->
            <ColumnDefinition Width="220"/>
            <!-- Main Chat Area -->
            <ColumnDefinition Width="*"/>
            <!-- Members panel (toggleable) -->
            <ColumnDefinition x:Name="MembersPanelColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ========== PROJECT ICON SIDEBAR (Column 0) ========== -->
        <Border Grid.Column="0" Grid.Row="0" Background="#12151A" BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- DT Logo -->
                    <RowDefinition Height="*"/>     <!-- Project icons -->
                </Grid.RowDefinitions>

                <!-- Home Button -->
                <Border Grid.Row="0" Padding="0,14,0,10" HorizontalAlignment="Center">
                    <Border x:Name="HomeButton" Width="44" Height="44" CornerRadius="12" Cursor="Hand"
                            MouseDown="HomeButton_Click"
                            ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#238636" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M12,2 L2,12 L5,12 L5,20 L10,20 L10,14 L14,14 L14,20 L19,20 L19,12 L22,12 Z"
                              Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="22" Height="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border.ToolTip>
                            <ToolTip Content="Home" Style="{StaticResource ProjectTooltipStyle}"/>
                        </Border.ToolTip>
                    </Border>
                </Border>

                <!-- Separator -->
                <Border Grid.Row="0" Height="2" Background="#30363D" VerticalAlignment="Bottom"
                        Margin="14,0" CornerRadius="1"/>

                <!-- Project icon list -->
                <ListBox x:Name="ProjectList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         SelectionChanged="ProjectList_SelectionChanged" Padding="0,8"
                         HorizontalContentAlignment="Center" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid>
                                            <!-- Selection indicator bar (left) -->
                                            <Border x:Name="SelectionIndicator" Width="4" Height="0" CornerRadius="0,2,2,0"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="#238636"/>
                                            <Border x:Name="ItemBg" Width="48" Height="48" CornerRadius="24"
                                                    Background="#1C2333" Margin="0,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBg" Property="CornerRadius" Value="16"/>
                                                <Setter TargetName="ItemBg" Property="Background" Value="#238636"/>
                                                <Setter TargetName="SelectionIndicator" Property="Height" Value="20"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBg" Property="CornerRadius" Value="16"/>
                                                <Setter TargetName="ItemBg" Property="Background" Value="#238636"/>
                                                <Setter TargetName="SelectionIndicator" Property="Height" Value="36"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                <TextBlock Text="{Binding IconLetters}" FontSize="16" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Grid.ToolTip>
                                    <ToolTip Content="{Binding name}" Style="{StaticResource ProjectTooltipStyle}"/>
                                </Grid.ToolTip>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Border>

        <!-- ========== CHANNEL LIST PANEL (Column 1) ========== -->
        <Border Grid.Column="1" Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Project name header -->
                    <RowDefinition Height="Auto"/>  <!-- Channels label + add btn -->
                    <RowDefinition Height="*"/>     <!-- Channel list -->
                </Grid.RowDefinitions>

                <!-- Project Name Header -->
                <Border Grid.Row="0" Padding="16,14,16,12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="SelectedProjectName" Text="Home" FontSize="15" FontWeight="Bold"
                               Foreground="#E6EDF3" TextTrimming="CharacterEllipsis"/>
                </Border>

                <!-- Channels section header -->
                <Grid x:Name="ChannelsSectionHeader" Grid.Row="1" Margin="16,12,16,4" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CHANNELS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"
                               VerticalAlignment="Center"/>
                    <Button x:Name="AddChannelButton" Grid.Column="1" Content="+" FontSize="16" FontWeight="Bold"
                            Foreground="#8B949E" Background="Transparent" BorderThickness="0"
                            Width="22" Height="22" Cursor="Hand" Click="AddChannelButton_Click"
                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                            ToolTip="Add Channel">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBg" CornerRadius="4" Background="Transparent"
                                        Width="22" Height="22">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBg" Property="Background" Value="#30363D"/>
                                        <Setter Property="Foreground" Value="#E6EDF3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Channel list -->
                <ListBox x:Name="ChannelList" Grid.Row="2" Background="Transparent" BorderThickness="0"
                         SelectionChanged="ChannelList_SelectionChanged" Padding="4,0"
                         ItemContainerStyle="{StaticResource ChannelItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="#" FontSize="16" Foreground="#8B949E" Margin="0,0,6,0"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="#B1BAC4" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Border>

        <!-- ========== MAIN CHAT AREA (Column 2) ========== -->
        <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">

            <!-- HOME VIEW (shown by default) -->
            <Grid x:Name="HomeView" Background="#0D1117">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,30" MaxWidth="700">
                        <!-- Welcome header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,16,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#238636" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M12,2 L2,12 L5,12 L5,20 L10,20 L10,14 L14,14 L14,20 L19,20 L19,12 L22,12 Z"
                                      Stroke="White" StrokeThickness="2" Fill="Transparent"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="HomeWelcomeText" Text="Welcome back!" FontSize="24" FontWeight="Bold" Foreground="#E6EDF3"/>
                                <TextBlock Text="Here's an overview of your workspace" FontSize="14" Foreground="#8B949E" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Stats cards -->
                        <TextBlock Text="YOUR PROJECTS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,12"/>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="HomeProjectCountText" Text="0 projects imported" FontSize="16" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Select a project from the sidebar to start collaborating" FontSize="13" Foreground="#8B949E" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="📂" FontSize="32" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Quick actions -->
                        <TextBlock Text="QUICK START" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,8,0,12"/>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Start chatting" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Click on a project in the sidebar, then select a channel" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Create a channel" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Each project starts with #general — add more channels as needed" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="View members" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Toggle the members panel from the chat header" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Project list on home -->
                        <TextBlock Text="PROJECT LIST" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,24,0,12"/>
                        <ItemsControl x:Name="HomeProjectList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="10" Background="#238636" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding IconLetters}" FontSize="13" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding name}" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                                <TextBlock Text="{Binding VisibilityLabel}" FontSize="11" Foreground="#8B949E"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- CHAT VIEW (hidden by default) -->
            <Grid x:Name="ChatView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Chat header -->
                <RowDefinition Height="*"/>      <!-- Messages -->
                <RowDefinition Height="Auto"/>   <!-- Message input -->
            </Grid.RowDefinitions>

            <!-- Chat Header -->
            <Border Grid.Row="0" Padding="20,14" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                    Background="#161B22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="#" FontSize="20" FontWeight="Bold" Foreground="#8B949E"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChatTitle" Text="general" FontSize="18" FontWeight="Bold"
                                       Foreground="#E6EDF3" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ChatSubtitle" Text="Select a project to start chatting"
                                   FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Toggle members panel button -->
                    <Button x:Name="ToggleMembersButton" Grid.Column="1" Cursor="Hand"
                            Click="ToggleMembersButton_Click" ToolTip="Toggle Members Panel">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBg" CornerRadius="6" Background="Transparent"
                                        Padding="8,6" BorderBrush="#30363D" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👥" FontSize="14" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="MemberCountText" Text="Members" FontSize="12"
                                                   Foreground="#8B949E" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBg" Property="Background" Value="#1C2333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Messages Area -->
            <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10">
                <ItemsControl x:Name="MessagesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <!-- System message -->
                                <Border Padding="12,8" CornerRadius="8" HorizontalAlignment="Center" Margin="40,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#161B22"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Content}" FontSize="13" Foreground="#8B949E"
                                                   TextWrapping="Wrap" TextAlignment="Center" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="#484F58"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- User message -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <!-- Avatar -->
                                    <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0"
                                            VerticalAlignment="Top"
                                            Background="{Binding AvatarColor}">
                                        <Grid>
                                            <TextBlock Text="{Binding Initials}" FontSize="12" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Image Width="36" Height="36"
                                                   Source="{Binding AvatarUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                                <Image.Clip>
                                                    <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                                                </Image.Clip>
                                            </Image>
                                        </Grid>
                                    </Border>
                                    <!-- Message content -->
                                    <StackPanel MaxWidth="500">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{Binding UsernameColor}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="#8B949E"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Content}" FontSize="14" Foreground="#E6EDF3"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Message Input -->
            <Border Grid.Row="2" Padding="20,12" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border CornerRadius="8" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" Padding="2">
                        <TextBox x:Name="MessageInput" Background="Transparent" BorderThickness="0"
                                 Foreground="#E6EDF3" FontSize="14" Padding="12,8"
                                 VerticalContentAlignment="Center"
                                 KeyDown="MessageInput_KeyDown">
                            <TextBox.CaretBrush>
                                <SolidColorBrush Color="#E6EDF3"/>
                            </TextBox.CaretBrush>
                        </TextBox>
                    </Border>
                    <Button Grid.Column="1" Content="➤" Width="40" Height="40" Margin="8,0,0,0"
                            FontSize="18" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="SendButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#238636" Offset="0"/>
                                <GradientStop Color="#2EA043" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="{TemplateBinding Background}" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            </Grid> <!-- End ChatView -->
        </Grid>

        <!-- ========== MEMBERS PANEL (Column 3) ========== -->
        <Border x:Name="MembersPanelBorder" Grid.Column="3" Grid.Row="0" Grid.RowSpan="2" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="1,0,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Members header -->
                <Border Grid.Row="0" Padding="16,14,16,12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                    <TextBlock Text="MEMBERS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"/>
                </Border>

                <!-- Members list -->
                <ListBox x:Name="MembersList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Padding="4,8" ItemContainerStyle="{StaticResource MemberItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="#30363D" Margin="0,0,10,0">
                                    <Grid>
                                        <TextBlock Text="{Binding Initials}" FontSize="11" FontWeight="Bold"
                                                   Foreground="#8B949E" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Image Width="32" Height="32"
                                               Source="{Binding AvatarUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                            <Image.Clip>
                                                <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                                            </Image.Clip>
                                        </Image>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Username}" FontSize="13" Foreground="#E6EDF3"/>
                                    <TextBlock Text="{Binding Role}" FontSize="11" Foreground="#8B949E"/>
                                </StackPanel>
                                <!-- Online indicator -->
                                <Border Width="8" Height="8" CornerRadius="4" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#484F58"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="Background" Value="#238636"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ========== UNIFIED USER PROFILE BAR (Row 1, spanning columns 0-1) ========== -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#12151A"
                BorderBrush="#30363D" BorderThickness="0,1,1,0" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- User avatar -->
                    <Border Width="32" Height="32" CornerRadius="16" Background="#30363D"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                        <Grid>
                            <TextBlock x:Name="UserInitials" Text="U" FontSize="12" FontWeight="Bold"
                                       Foreground="#8B949E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="UserAvatarImage" Width="32" Height="32" Visibility="Collapsed">
                                <Image.Clip>
                                    <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="UsernameText" Text="user" FontSize="13" Foreground="#E6EDF3"
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Logout button -->
                <Button Grid.Column="1" Cursor="Hand" Click="LogoutButton_Click" ToolTip="Logout">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="LogoutBg" CornerRadius="6" Background="Transparent"
                                    Width="30" Height="30">
                                <!-- Logout/door icon -->
                                <Path Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"
                                      Fill="#8B949E" Stretch="Uniform" Width="16" Height="16"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="LogoutBg" Property="Background" Value="#30363D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ========== ADD CHANNEL POPUP OVERLAY ========== -->
        <Grid x:Name="AddChannelOverlay" Grid.ColumnSpan="4" Grid.RowSpan="2" Visibility="Collapsed">
            <!-- Dark backdrop -->
            <Border Background="#80000000" MouseDown="AddChannelOverlay_MouseDown"/>

            <!-- Popup dialog -->
            <Border Width="400" Height="200" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Create Channel" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Enter a name for the new channel" FontSize="12"
                               Foreground="#8B949E" Margin="0,0,0,16"/>

                    <Border Grid.Row="2" CornerRadius="6" Background="#0D1117" BorderBrush="#30363D"
                            BorderThickness="1" Padding="2" VerticalAlignment="Center">
                        <TextBox x:Name="NewChannelNameInput" Background="Transparent" BorderThickness="0"
                                 Foreground="#E6EDF3" FontSize="14" Padding="10,8"
                                 VerticalContentAlignment="Center"
                                 KeyDown="NewChannelNameInput_KeyDown">
                            <TextBox.CaretBrush>
                                <SolidColorBrush Color="#E6EDF3"/>
                            </TextBox.CaretBrush>
                        </TextBox>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                                Click="CancelAddChannel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CancelBg" CornerRadius="6" Background="Transparent"
                                            BorderBrush="#30363D" BorderThickness="1" Padding="16,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CancelBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="#8B949E"/>
                            </Button.Foreground>
                        </Button>
                        <Button Content="Create" Padding="16,8" Cursor="Hand"
                                Click="ConfirmAddChannel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CreateBg" CornerRadius="6" Padding="16,8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#238636" Offset="0"/>
                                                <GradientStop Color="#2EA043" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CreateBg" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== CHANNEL SETTINGS OVERLAY ========== -->
        <Grid x:Name="ChannelSettingsOverlay" Grid.ColumnSpan="4" Grid.RowSpan="2" Visibility="Collapsed">
            <!-- Dark backdrop -->
            <Border Background="#80000000" MouseDown="ChannelSettingsOverlay_MouseDown"/>

            <!-- Settings dialog -->
            <Border Width="480" MinHeight="340" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="Auto"/>  <!-- Tab bar -->
                        <RowDefinition Height="*"/>     <!-- Tab content -->
                        <RowDefinition Height="Auto"/>  <!-- Footer / danger zone -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="24,18,24,14" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="#" FontSize="18" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SettingsChannelTitle" Text="general" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Channel Settings" FontSize="12" Foreground="#8B949E" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Close button -->
                            <Button Grid.Column="1" Cursor="Hand" Click="CloseChannelSettings_Click" ToolTip="Close" VerticalAlignment="Top">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBg" CornerRadius="6" Background="Transparent" Width="28" Height="28">
                                            <Path Data="M18,6 L6,18 M6,6 L18,18" Stroke="#8B949E" StrokeThickness="1.5"
                                                  Stretch="Uniform" Width="12" Height="12"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBg" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Tab bar -->
                    <Border Grid.Row="1" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="24,0,24,0">
                            <!-- Overview Tab -->
                            <Button x:Name="TabOverviewBtn" Cursor="Hand" Click="TabOverview_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBg" Padding="12,10" Background="Transparent"
                                                BorderBrush="#238636" BorderThickness="0,0,0,2">
                                            <TextBlock Text="Overview" FontSize="13" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Permissions Tab -->
                            <Button x:Name="TabPermissionsBtn" Cursor="Hand" Click="TabPermissions_Click" Margin="4,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBg" Padding="12,10" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                            <TextBlock x:Name="TabText" Text="Permissions" FontSize="13" Foreground="#8B949E"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#E6EDF3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Tab Content -->
                    <Grid Grid.Row="2" Margin="24,16,24,16">
                        <!-- Overview Tab Content -->
                        <StackPanel x:Name="OverviewTabContent" Visibility="Visible">
                            <TextBlock Text="CHANNEL NAME" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,8"/>
                            <Border CornerRadius="6" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" Padding="2">
                                <TextBox x:Name="EditChannelNameInput" Background="Transparent" BorderThickness="0"
                                         Foreground="#E6EDF3" FontSize="14" Padding="10,8"
                                         VerticalContentAlignment="Center">
                                    <TextBox.CaretBrush>
                                        <SolidColorBrush Color="#E6EDF3"/>
                                    </TextBox.CaretBrush>
                                </TextBox>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Save Changes" Padding="16,8" Cursor="Hand"
                                        Click="SaveChannelName_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="SaveBg" CornerRadius="6" Padding="16,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#238636" Offset="0"/>
                                                        <GradientStop Color="#2EA043" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="SaveBg" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground>
                                        <SolidColorBrush Color="White"/>
                                    </Button.Foreground>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Permissions Tab Content -->
                        <StackPanel x:Name="PermissionsTabContent" Visibility="Collapsed">
                            <Border Background="#0D1117" CornerRadius="8" Padding="20,24" Margin="0,0,0,8">
                                <StackPanel HorizontalAlignment="Center">
                                    <!-- Lock icon as vector Path -->
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#1C2333" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <Path Data="M12,17A2,2 0 0,0 14,15A2,2 0 0,0 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10A2,2 0 0,1 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                              Fill="#8B949E" Stretch="Uniform" Width="20" Height="20"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Permissions coming soon" FontSize="15" FontWeight="SemiBold" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Channel permission management will be available in a future update." FontSize="12" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Danger Zone (Delete) -->
                    <Border Grid.Row="3" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="24,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Danger Zone" FontSize="13" FontWeight="SemiBold" Foreground="#F85149"/>
                                <TextBlock Text="Permanently delete this channel and all its messages" FontSize="11" Foreground="#8B949E" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Delete Channel" Padding="14,7" Cursor="Hand"
                                    Click="DeleteChannel_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DelBg" CornerRadius="6" Padding="14,7"
                                                Background="Transparent" BorderBrush="#F85149" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DelBg" Property="Background" Value="#F85149"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Foreground>
                                    <SolidColorBrush Color="#F85149"/>
                                </Button.Foreground>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== DELETE CONFIRMATION OVERLAY ========== -->
        <Grid x:Name="DeleteConfirmOverlay" Grid.ColumnSpan="4" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#AA000000" MouseDown="DeleteConfirmOverlay_BackdropClick"/>

            <Border Width="420" Background="#161B22" CornerRadius="12"
                    BorderBrush="#30363D" BorderThickness="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Padding="24,20">
                <StackPanel>
                    <!-- Warning icon -->
                    <Border Width="48" Height="48" CornerRadius="24" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <SolidColorBrush Color="#F85149" Opacity="0.15"/>
                        </Border.Background>
                        <Path Data="M12,2 L1,21 L23,21 Z M12,9 L12,15 M12,17 L12,19"
                              Stroke="#F85149" StrokeThickness="1.8" Fill="Transparent"
                              Stretch="Uniform" Width="24" Height="24"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Delete Channel" FontSize="18" FontWeight="Bold"
                               Foreground="#E6EDF3" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DeleteConfirmMessage" TextWrapping="Wrap" TextAlignment="Center"
                               FontSize="13" Foreground="#8B949E" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Cancel" Padding="20,9" Margin="0,0,10,0" Cursor="Hand"
                                Click="DeleteConfirmCancel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CancelBg" CornerRadius="6" Background="Transparent"
                                            BorderBrush="#30363D" BorderThickness="1" Padding="20,9">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CancelBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="#8B949E"/>
                            </Button.Foreground>
                        </Button>
                        <Button Content="Delete" Padding="20,9" Cursor="Hand"
                                Click="DeleteConfirmYes_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="DelBg" CornerRadius="6" Padding="20,9"
                                            Background="#F85149">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DelBg" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
