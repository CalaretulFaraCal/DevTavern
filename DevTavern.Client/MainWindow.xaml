<Window x:Class="DevTavern.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DevTavern.Client"
        xmlns:avalonedit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        Title="DevTavern" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Tooltip style with arrow indicator -->
        <Style x:Key="ProjectTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#1C2333"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="HorizontalOffset" Value="14"/>
            <Setter Property="HasDropShadow" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Arrow pointing left toward icon -->
                            <Path Grid.Column="0" Data="M 8,0 L 0,8 L 8,16" Fill="#1C2333" Stroke="#30363D"
                                  StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,-1,0"/>
                            <Border Grid.Column="1" Background="#1C2333" BorderBrush="#30363D" BorderThickness="1"
                                    CornerRadius="6" Padding="10,6">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                                </Border.Effect>
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Channel list item style -->
        <Style x:Key="ChannelItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBg" CornerRadius="4" Padding="8,6" Background="Transparent" Margin="4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" HorizontalAlignment="Stretch"/>
                                <!-- Gear icon — part of the ListBoxItem template so IsMouseOver works on the whole row -->
                                <Button x:Name="GearBtn" Grid.Column="1" Cursor="Hand"
                                        Click="ChannelSettingsBtn_Click"
                                        ToolTip="Channel Settings"
                                        Visibility="Hidden">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="GearBg" CornerRadius="4" Background="Transparent"
                                                    Width="22" Height="22">
                                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                                      Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="GearBg" Property="Background" Value="#30363D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                <Setter TargetName="GearBtn" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                <Setter TargetName="ItemBg" Property="BorderBrush" Value="#30363D"/>
                                <Setter TargetName="ItemBg" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Voice channel list item style -->
        <Style x:Key="VoiceChannelItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBg" CornerRadius="4" Padding="8,6" Background="Transparent" Margin="4,0">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Members list item style -->
        <Style x:Key="MemberItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border CornerRadius="4" Padding="8,6" Background="Transparent" Margin="4,0">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox for voice settings -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E6EDF3"/>
                        <Setter Property="Background" Value="#161B22"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TgBorder" Background="#0D1117" BorderBrush="#30363D"
                                                BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M7,10L12,15L17,10Z" Fill="#8B949E"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TgBorder" Property="BorderBrush" Value="#8B949E"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TgBorder" Property="BorderBrush" Value="#238636"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="12,0,32,0" VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220"
                                        Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                                        CornerRadius="6" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.4" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim slider for voice settings -->
        <Style x:Key="VoiceSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#238636" CornerRadius="2,0,0,2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14" Fill="White"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#30363D" CornerRadius="0,2,2,0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch (CheckBox) for voice settings -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                            <Border x:Name="Track" Grid.Column="1" Width="40" Height="22"
                                    CornerRadius="11" Background="#30363D">
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White"
                                         HorizontalAlignment="Left" VerticalAlignment="Center"
                                         Margin="3,0,0,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#238636"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Radio button for voice detection mode -->
        <Style x:Key="VoiceRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Outer" Width="18" Height="18" CornerRadius="9"
                                    BorderBrush="#30363D" BorderThickness="2" Background="Transparent"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                <Ellipse x:Name="Inner" Width="8" Height="8" Fill="#238636" Visibility="Collapsed"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="#238636"/>
                                <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="#8B949E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Project icon sidebar -->
            <ColumnDefinition Width="72"/>
            <!-- Channel list -->
            <ColumnDefinition Width="220"/>
            <!-- Main Chat Area -->
            <ColumnDefinition Width="*"/>
            <!-- Resize splitter between chat and side panel -->
            <ColumnDefinition x:Name="SplitterColumn" Width="0"/>
            <!-- Side panel: Members or Code Browser (toggleable) -->
            <ColumnDefinition x:Name="MembersPanelColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ========== PROJECT ICON SIDEBAR (Column 0) ========== -->
        <Border Grid.Column="0" Grid.Row="0" Background="#12151A" BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- DT Logo -->
                    <RowDefinition Height="*"/>     <!-- Project icons -->
                    <RowDefinition Height="Auto"/>  <!-- Add Project Button -->
                </Grid.RowDefinitions>

                <!-- Home Button -->
                <Border Grid.Row="0" Padding="0,14,0,10" HorizontalAlignment="Center">
                    <Border x:Name="HomeButton" Width="44" Height="44" CornerRadius="12" Cursor="Hand"
                            MouseDown="HomeButton_Click"
                            ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#238636" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M12,2 L2,12 L5,12 L5,20 L10,20 L10,14 L14,14 L14,20 L19,20 L19,12 L22,12 Z"
                              Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="22" Height="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border.ToolTip>
                            <ToolTip Content="Home" Style="{StaticResource ProjectTooltipStyle}"/>
                        </Border.ToolTip>
                    </Border>
                </Border>

                <!-- Separator -->
                <Border Grid.Row="0" Height="2" Background="#30363D" VerticalAlignment="Bottom"
                        Margin="14,0" CornerRadius="1"/>

                <!-- Project icon list -->
                <ListBox x:Name="ProjectList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         SelectionChanged="ProjectList_SelectionChanged" Padding="0,8"
                         HorizontalContentAlignment="Center" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid>
                                            <!-- Selection indicator bar (left) -->
                                            <Border x:Name="SelectionIndicator" Width="4" Height="0" CornerRadius="0,2,2,0"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="#238636"/>
                                            <Border x:Name="ItemBg" Width="48" Height="48" CornerRadius="24"
                                                    Background="#1C2333" Margin="0,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBg" Property="CornerRadius" Value="16"/>
                                                <Setter TargetName="ItemBg" Property="Background" Value="#238636"/>
                                                <Setter TargetName="SelectionIndicator" Property="Height" Value="20"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBg" Property="CornerRadius" Value="16"/>
                                                <Setter TargetName="ItemBg" Property="Background" Value="#238636"/>
                                                <Setter TargetName="SelectionIndicator" Property="Height" Value="36"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="48" Height="48" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                <TextBlock Text="{Binding IconLetters}" FontSize="16" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Badge rosu cu numarul de mentiuni nevazute (colt dreapta-sus) -->
                                <Border Background="#DA3633" CornerRadius="8" MinWidth="16" Height="16"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-4,-4,0" Padding="4,0"
                                        Visibility="{Binding HasMentions, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding UnreadMentionCount}" FontSize="10" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Bulina alba pentru mesaje necitite (colt dreapta-jos) -->
                                <Ellipse Width="11" Height="11" Fill="White"
                                         Stroke="#161B22" StrokeThickness="1.5"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,3,3"
                                         Visibility="{Binding HasUnreadMessages, Converter={StaticResource BoolToVis}}"/>

                                <Grid.ToolTip>
                                    <ToolTip Content="{Binding name}" Style="{StaticResource ProjectTooltipStyle}"/>
                                </Grid.ToolTip>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Add Project Button -->
                <Border Grid.Row="2" Padding="0,10,0,14" HorizontalAlignment="Center">
                    <Border x:Name="AddProjectButton" Width="48" Height="48" CornerRadius="24" Cursor="Hand" Background="#1C2333" HorizontalAlignment="Center" MouseDown="AddProjectButton_MouseDown">
                        <TextBlock Text="+" FontSize="28" FontWeight="SemiBold" Foreground="#238636" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-4,0,0"/>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="CornerRadius" Value="16"/>
                                        <Setter Property="Background" Value="#238636"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- ========== CHANNEL LIST PANEL (Column 1) ========== -->
        <Border Grid.Column="1" Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Project name header (sticky) -->
                    <RowDefinition Height="*"/>     <!-- Scrollable channel sections -->
                    <RowDefinition Height="Auto"/>  <!-- Voice connected bar (sticky bottom) -->
                </Grid.RowDefinitions>

                <!-- Project Name Header -->
                <Border Grid.Row="0" Padding="16,14,16,12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectedProjectName" Text="Home" FontSize="15" FontWeight="Bold"
                                   Foreground="#E6EDF3" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <!-- Set Roles button -->
                        <Button Grid.Column="1" Cursor="Hand" Click="SetRoleButton_Click" ToolTip="Set Roles" Margin="8,0,0,0" Width="24" Height="24">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="RolesBg" CornerRadius="4" Background="Transparent">
                                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                              Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RolesBg" Property="Background" Value="#30363D"/>
                                            <Setter Property="Foreground" Value="#E6EDF3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Scrollable channel sections -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- TEXT CHANNELS header -->
                        <Grid x:Name="ChannelsSectionHeader" Margin="16,12,16,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TEXT CHANNELS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="AddChannelButton" Grid.Column="1" Content="+" FontSize="16" FontWeight="Bold"
                                    Foreground="#8B949E" Background="Transparent" BorderThickness="0"
                                    Width="22" Height="22" Cursor="Hand" Click="AddChannelButton_Click"
                                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                    ToolTip="Add Channel">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBg" CornerRadius="4" Background="Transparent" Width="22" Height="22">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBg" Property="Background" Value="#30363D"/>
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Text channel list -->
                        <ListBox x:Name="ChannelList" Background="Transparent" BorderThickness="0"
                                 SelectionChanged="ChannelList_SelectionChanged" Padding="4,0"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource ChannelItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasUnreadMessages}" Value="True">
                                                                <Setter Property="Fill" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="#" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8B949E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasUnreadMessages}" Value="True">
                                                                <Setter Property="Foreground" Value="#C9D1D9"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8B949E"/>
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasUnreadMessages}" Value="True">
                                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Red mention badge -->
                                        <Border Grid.Column="1" CornerRadius="8"
                                                MinWidth="18" Height="18" Padding="4,0" Margin="4,0,0,0"
                                                VerticalAlignment="Center" Background="#DA3633">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasMentions}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding UnreadMentionCount}" FontSize="10" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- VOICE CHANNELS header -->
                        <Grid x:Name="VoiceChannelsSectionHeader" Margin="16,12,16,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="VOICE CHANNELS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="AddVoiceChannelButton" Grid.Column="1" Content="+" FontSize="16" FontWeight="Bold"
                                    Foreground="#8B949E" Background="Transparent" BorderThickness="0"
                                    Width="22" Height="22" Cursor="Hand" Click="AddVoiceChannelButton_Click"
                                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                    ToolTip="Add Voice Channel">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBg" CornerRadius="4" Background="Transparent" Width="22" Height="22">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBg" Property="Background" Value="#30363D"/>
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Voice channel list -->
                        <ListBox x:Name="VoiceChannelList" Background="Transparent" BorderThickness="0"
                                 Padding="4,0" Visibility="Collapsed"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource VoiceChannelItemStyle}"
                                 SelectionChanged="VoiceChannelList_SelectionChanged"
                                 PreviewMouseRightButtonDown="VoiceChannelList_PreviewMouseRightButtonDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- Channel row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                                <Path Stretch="Uniform" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                      Data="M3,9V15H7L12,20V4L7,9H3M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12Z">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Fill" Value="#8B949E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsJoined}" Value="True">
                                                                    <Setter Property="Fill" Value="#3FB950"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#8B949E"/>
                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsJoined}" Value="True">
                                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- Mic indicator when joined -->
                                            <Path Grid.Column="1" Stretch="Uniform" Width="12" Height="12" VerticalAlignment="Center"
                                                  Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z"
                                                  Fill="#3FB950">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsJoined}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Grid>
                                        <!-- Members in this voice channel -->
                                        <ItemsControl ItemsSource="{Binding VoiceMembers}" Margin="20,2,0,2">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2" VerticalAlignment="Center">
                                                        <!-- Person icon -->
                                                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                                              Fill="#8B949E" Stretch="Uniform" Width="12" Height="12"
                                                              Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <!-- Username -->
                                                        <TextBlock Text="{Binding Username}" FontSize="12" Foreground="#8B949E" VerticalAlignment="Center"/>
                                                        <!-- Muted indicator -->
                                                        <Path Data="M19,11C19,12.19 18.66,13.3 18.1,14.28L16.87,13.05C17.14,12.43 17.3,11.74 17.3,11H19M15,11.16L9,5.18V5A3,3 0 0,1 12,2A3,3 0 0,1 15,5V11L15,11.16M4.27,3L21,19.73L19.73,21L15.54,16.81C14.77,17.27 13.91,17.58 13,17.72V21H11V17.72C7.72,17.23 5,14.41 5,11H6.7C6.7,14 9.24,16.1 12,16.1C12.81,16.1 13.6,15.91 14.31,15.58L12.65,13.92L12,14A3,3 0 0,1 9,11V10.27L4.27,3Z"
                                                              Fill="#DA3633" Stretch="Uniform" Width="10" Height="10"
                                                              Margin="4,0,0,0" VerticalAlignment="Center"
                                                              Visibility="{Binding IsMuted, Converter={StaticResource BoolToVis}}"/>
                                                        <!-- Deafened indicator -->
                                                        <Path Data="M12,1C7,1 3,5 3,10V17A3,3 0 0,0 6,20H9V12H5V10A7,7 0 0,1 12,3A7,7 0 0,1 19,10V12H15V20H18A3,3 0 0,0 21,17V10C21,5 16.97,1 12,1Z"
                                                              Fill="#DA3633" Stretch="Uniform" Width="10" Height="10"
                                                              Margin="2,0,0,0" VerticalAlignment="Center"
                                                              Visibility="{Binding IsDeafened, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </ScrollViewer>

                <!-- Voice connected bar (sticky bottom) -->
                <Border x:Name="VoiceConnectedBar" Grid.Row="2" Background="#1C2333"
                        BorderBrush="#30363D" BorderThickness="0,1,0,0"
                        Padding="10,8" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Status text -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Voice Connected" FontSize="11" FontWeight="SemiBold" Foreground="#3FB950"/>
                            <TextBlock x:Name="VoiceConnectedChannelName" FontSize="11" Foreground="#8B949E" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <!-- Controls: mute, deafen, leave -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Mute button -->
                            <Button Cursor="Hand" Click="MuteVoice_Click" ToolTip="Mute" VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="4" Background="Transparent" Padding="5,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path x:Name="MuteIcon"
                                      Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z"
                                      Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <!-- Deafen button -->
                            <Button Cursor="Hand" Click="DeafenVoice_Click" ToolTip="Deafen" VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="4" Background="Transparent" Padding="5,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path x:Name="DeafenIcon"
                                      Data="M12,1C7,1 3,5 3,10V17A3,3 0 0,0 6,20H9V12H5V10A7,7 0 0,1 12,3A7,7 0 0,1 19,10V12H15V20H18A3,3 0 0,0 21,17V10C21,5 16.97,1 12,1Z"
                                      Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <!-- Leave button -->
                            <Button Cursor="Hand" Click="LeaveVoiceChannel_Click" ToolTip="Disconnect" VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="LeaveBg" CornerRadius="4" Background="Transparent" Padding="5,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="LeaveBg" Property="Background" Value="#DA3633"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path Data="M19,3H5C3.89,3 3,3.89 3,5V9H5V5H19V19H5V15H3V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M10.08,15.58L11.5,17L16.5,12L11.5,7L10.08,8.41L12.67,11H3V13H12.67L10.08,15.58Z"
                                      Fill="#8B949E" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ========== MAIN CHAT AREA (Column 2) ========== -->
        <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">

            <!-- HOME VIEW (shown by default) -->
            <Grid x:Name="HomeView" Background="#0D1117">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,30" MaxWidth="700">
                        <!-- Welcome header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,16,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#238636" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M12,2 L2,12 L5,12 L5,20 L10,20 L10,14 L14,14 L14,20 L19,20 L19,12 L22,12 Z"
                                      Stroke="White" StrokeThickness="2" Fill="Transparent"
                                      Stretch="Uniform" Width="28" Height="28"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="HomeWelcomeText" Text="Welcome back!" FontSize="24" FontWeight="Bold" Foreground="#E6EDF3"/>
                                <TextBlock Text="Here's an overview of your workspace" FontSize="14" Foreground="#8B949E" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Stats cards -->
                        <TextBlock Text="YOUR PROJECTS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,12"/>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="HomeProjectCountText" Text="0 projects imported" FontSize="16" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Select a project from the sidebar to start collaborating" FontSize="13" Foreground="#8B949E" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="📂" FontSize="32" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Quick actions -->
                        <TextBlock Text="QUICK START" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,8,0,12"/>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Start chatting" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Click on a project in the sidebar, then select a channel" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Create a channel" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Each project starts with #general — add more channels as needed" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#161B22" CornerRadius="10" BorderBrush="#30363D" BorderThickness="1" Padding="20,16" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="View members" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                    <TextBlock Text="Toggle the members panel from the chat header" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Project list on home -->
                        <TextBlock Text="PROJECT LIST" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,24,0,12"/>
                        <ItemsControl x:Name="HomeProjectList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161B22" CornerRadius="8" BorderBrush="#30363D" BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="10" Background="#238636" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding IconLetters}" FontSize="13" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding name}" FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                                <TextBlock Text="{Binding VisibilityLabel}" FontSize="11" Foreground="#8B949E"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- CHAT VIEW (hidden by default) -->
            <Grid x:Name="ChatView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Chat header -->
                <RowDefinition Height="*"/>      <!-- Messages -->
                <RowDefinition Height="Auto"/>   <!-- Message input -->
            </Grid.RowDefinitions>

            <!-- Chat Header -->
            <Border Grid.Row="0" Padding="20,14" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                    Background="#161B22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="#" FontSize="20" FontWeight="Bold" Foreground="#8B949E"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChatTitle" Text="general" FontSize="18" FontWeight="Bold"
                                       Foreground="#E6EDF3" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ChatSubtitle" Text="Select a project to start chatting"
                                   FontSize="12" Foreground="#8B949E" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Browse Code button -->
                        <Button x:Name="BrowseCodeButton" Cursor="Hand"
                                Click="BrowseCodeButton_Click" ToolTip="Browse Repository Code" Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CodeBtnBg" CornerRadius="6" Background="Transparent"
                                            Padding="8,6" BorderBrush="#30363D" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Code bracket icon -->
                                            <Path Data="M9.4,16.6L4.8,12L9.4,7.4L8,6L2,12L8,18L9.4,16.6M14.6,16.6L19.2,12L14.6,7.4L16,6L22,12L16,18L14.6,16.6Z"
                                                  Fill="#C9D1D9" Stretch="Uniform" Width="14" Height="14"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Code" FontSize="12"
                                                       Foreground="#C9D1D9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CodeBtnBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Toggle members panel button -->
                        <Button x:Name="ToggleMembersButton" Cursor="Hand"
                                Click="ToggleMembersButton_Click" ToolTip="Toggle Members Panel">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBg" CornerRadius="6" Background="Transparent"
                                            Padding="8,6" BorderBrush="#30363D" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                                  Fill="#C9D1D9" Stretch="Uniform" Width="14" Height="14"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="MemberCountText" Text="Members" FontSize="12"
                                                       Foreground="#C9D1D9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBg" Property="Background" Value="#1C2333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages Area -->
            <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10">
                <ItemsControl x:Name="MessagesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <!-- Date separator -->
                                <Grid Margin="0,6">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDateSeparator}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Height="1" Fill="#30363D" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DateLabel}" Margin="12,0"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"
                                               VerticalAlignment="Center"/>
                                    <Rectangle Grid.Column="2" Height="1" Fill="#30363D" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- System message -->
                                <Border Padding="12,8" CornerRadius="8" HorizontalAlignment="Center" Margin="40,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#161B22"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock local:TextBlockHelper.FormattedText="{Binding DisplayContent}" FontSize="13" Foreground="#8B949E"
                                                   TextWrapping="Wrap" TextAlignment="Center" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="#484F58"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- User message -->
                                <Border Padding="8,4,8,8" CornerRadius="8" Margin="-8,0,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="4,0,0,0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDateSeparator}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <!-- If a user is mentioned, highlight the message -->
                                                <DataTrigger Binding="{Binding IsMentioningMe}" Value="True">
                                                    <Setter Property="Background" Value="#33d29922"/>
                                                    <Setter Property="BorderBrush" Value="#d29922"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                        <!-- Avatar -->
                                        <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0"
                                                VerticalAlignment="Top"
                                                Background="{Binding AvatarColor}">
                                            <Grid>
                                                <TextBlock Text="{Binding Initials}" FontSize="12" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <Image Width="36" Height="36"
                                                       Source="{Binding AvatarUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                    <Image.Clip>
                                                        <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                        </Border>
                                        <!-- Message content -->
                                        <StackPanel MaxWidth="500">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{Binding UsernameColor}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="#8B949E"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="Jump to Code" Margin="12,0,0,0" Padding="8,2" VerticalAlignment="Center"
                                                        Cursor="Hand" Click="JumpToCode_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Background" Value="#238636"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Path Data="M9.4,16.6L4.8,12L9.4,7.4L8,6L2,12L8,18M14.6,16.6L19.2,12L14.6,7.4L16,6L22,12L16,18" 
                                                                                      Fill="White" Stretch="Uniform" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasCodeReference}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2EA043"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock local:TextBlockHelper.FormattedText="{Binding DisplayContent}" FontSize="14" Foreground="#E6EDF3"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            <Border Margin="0,8,0,0" Padding="12" CornerRadius="6"
                                                    Background="#0D1117" BorderBrush="#30363D" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCodeReference}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <avalonedit:TextEditor
                                                    local:AvalonEditHelper.FileExtension="{Binding CodeFileExtension}"
                                                    local:AvalonEditHelper.BindableText="{Binding CodeSelectedText}"
                                                    IsReadOnly="True"
                                                    ShowLineNumbers="False"
                                                    MaxHeight="250"
                                                    HorizontalScrollBarVisibility="Auto"
                                                    VerticalScrollBarVisibility="Auto"
                                                    Background="#0D1117"
                                                    Foreground="#C9D1D9"
                                                    FontFamily="Consolas, Courier New"
                                                    FontSize="13"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Message Input -->
            <Border Grid.Row="2" Padding="20,12" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Mention Popup -->
                        <Border Grid.Row="0" Margin="0,0,0,4" CornerRadius="8" 
                                Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                                Panel.ZIndex="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                            </Border.Effect>
                            <ListBox x:Name="MentionPopup" Visibility="Collapsed" MaxHeight="200" Background="Transparent" 
                                     BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="MentionPopup_SelectionChanged" KeyDown="MentionPopup_KeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Foreground" Value="#E6EDF3"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="BgBorder" CornerRadius="4" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BgBorder" Property="Background" Value="#1C2333"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="BgBorder" Property="Background" Value="#238636"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="@" Foreground="#8B949E" FontWeight="Bold" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Username}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Row="1" CornerRadius="8" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" Padding="2" MaxHeight="140">
                            <TextBox x:Name="MessageInput" Background="Transparent" BorderThickness="0"
                                     Foreground="#E6EDF3" FontSize="14" Padding="12,8"
                                     VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="False"
                                     VerticalScrollBarVisibility="Auto"
                                     PreviewKeyDown="MessageInput_KeyDown"
                                     TextChanged="MessageInput_TextChanged">
                                <TextBox.CaretBrush>
                                    <SolidColorBrush Color="#E6EDF3"/>
                                </TextBox.CaretBrush>
                            </TextBox>
                        </Border>
                    </Grid>
                    <Button Grid.Column="1" VerticalAlignment="Bottom" Content="➤" Width="40" Height="40" Margin="8,0,0,0"
                            FontSize="18" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="SendButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#238636" Offset="0"/>
                                <GradientStop Color="#2EA043" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="{TemplateBinding Background}" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            </Grid> <!-- End ChatView -->
        </Grid>

        <!-- GridSplitter for resizing code browser panel -->
        <GridSplitter x:Name="CodeBrowserSplitter" Grid.Column="3" Grid.Row="0" Grid.RowSpan="2"
                      Width="5" HorizontalAlignment="Stretch"
                      Background="#21262D" Cursor="SizeWE"
                      Visibility="Collapsed">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="#21262D">
                        <Rectangle Width="2" Height="24" Fill="#484F58" RadiusX="1" RadiusY="1"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- ========== SIDE PANEL (Column 4) — Members OR Code Browser ========== -->
        <Grid Grid.Column="4" Grid.Row="0" Grid.RowSpan="2">

            <!-- MEMBERS PANEL -->
            <Border x:Name="MembersPanelBorder" Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1,0,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Members header -->
                    <Border Grid.Row="0" Padding="16,14,16,12" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                        <TextBlock Text="MEMBERS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"/>
                    </Border>

                    <!-- Members list -->
                    <ListBox x:Name="MembersList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                             Padding="4,8" ItemContainerStyle="{StaticResource MemberItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Header variant -->
                                    <TextBlock Text="{Binding Username}" FontSize="12" FontWeight="Bold" Foreground="#8B949E" Margin="0,16,0,8">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <!-- User variant -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Border Width="32" Height="32" CornerRadius="16" Background="#30363D" Margin="0,0,10,0">
                                            <Grid>
                                                <TextBlock Text="{Binding Initials}" FontSize="11" FontWeight="Bold"
                                                           Foreground="#8B949E" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <Image Width="32" Height="32"
                                                       Source="{Binding AvatarUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                    <Image.Clip>
                                                        <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}" FontSize="13" Foreground="#E6EDF3"/>
                                            <TextBlock Text="{Binding Role}" FontSize="11" Foreground="#8B949E"/>
                                        </StackPanel>
                                        <!-- Online indicator -->
                                        <Border Width="8" Height="8" CornerRadius="4" Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#484F58"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                            <Setter Property="Background" Value="#238636"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- CODE BROWSER PANEL -->
            <Border x:Name="CodeBrowserPanel" Background="#0D1117"
                    BorderBrush="#30363D" BorderThickness="1,0,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header with branch selector -->
                        <RowDefinition Height="*"/>      <!-- Content: tree + viewer -->
                    </Grid.RowDefinitions>

                    <!-- Code Browser Header -->
                    <Border Grid.Row="0" Padding="12,10" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                            Background="#161B22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Repo info (left) -->
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock x:Name="CodeBrowserTitle" Text="Repository" FontSize="13"
                                           FontWeight="Bold" Foreground="#E6EDF3" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="CodeBrowserSubtitle" Text="" FontSize="11"
                                           Foreground="#8B949E" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Branch Selector (center/right, fills remaining space) -->
                            <Border Grid.Column="1" CornerRadius="6" Background="#0D1117"
                                    BorderBrush="#30363D" BorderThickness="1"
                                    VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Margin="0,0,8,0">
                                <ComboBox x:Name="CodeBranchSelector"
                                          SelectionChanged="CodeBranchSelector_SelectionChanged"
                                          FontSize="12" MinWidth="120" Height="28">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Foreground" Value="#E6EDF3"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBox">
                                                        <Grid>
                                                            <ToggleButton x:Name="ToggleButton" Focusable="False"
                                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          ClickMode="Press">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent" Padding="6,2">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <!-- Branch icon -->
                                                                                <Path Grid.Column="0" Data="M6,2V8C6,8 6,10 8,10H12C12,10 14,10 14,12V22M14,2V6"
                                                                                      Stroke="#8B949E" StrokeThickness="1.5"
                                                                                      Stretch="Uniform" Width="12" Height="12"
                                                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                <!-- Placeholder for spacing -->
                                                                                <Border Grid.Column="1"/>
                                                                                <!-- Dropdown arrow -->
                                                                                <Path Grid.Column="2" Data="M7,10L12,15L17,10Z"
                                                                                      Fill="#8B949E" Stretch="Uniform"
                                                                                      Width="8" Height="8"
                                                                                      VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="ContentSite"
                                                                              IsHitTestVisible="False"
                                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                              Margin="24,2,22,2"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Left">
                                                                <ContentPresenter.Resources>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#E6EDF3"/>
                                                                        <Setter Property="FontSize" Value="12"/>
                                                                    </Style>
                                                                </ContentPresenter.Resources>
                                                            </ContentPresenter>
                                                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                   AllowsTransparency="True" Focusable="False"
                                                                   PopupAnimation="Slide">
                                                                <Border Background="#161B22" BorderBrush="#30363D"
                                                                        BorderThickness="1" CornerRadius="6"
                                                                        Margin="0,2,0,0" Padding="4"
                                                                        MaxHeight="300" MinWidth="{TemplateBinding ActualWidth}">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.5" Color="Black"/>
                                                                    </Border.Effect>
                                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                        <StackPanel IsItemsHost="True"/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </Popup>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.Style>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Foreground" Value="#C9D1D9"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border x:Name="ItemBg" CornerRadius="4"
                                                                Background="Transparent" Padding="8,5">
                                                            <TextBlock Text="{Binding}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ItemBg" Property="Background" Value="#1C2333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ItemBg" Property="Background" Value="#238636"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                            </Border>

                            <!-- Close button (far right) -->
                            <Button Grid.Column="2" Cursor="Hand" Click="CloseCodeBrowser_Click" ToolTip="Close Code Browser">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBg" CornerRadius="4" Background="Transparent"
                                                Width="26" Height="26">
                                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                                  Fill="#8B949E" Stretch="Uniform" Width="12" Height="12"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBg" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Content: Split into file tree (right) and code viewer (left) -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" MinWidth="150"/>  <!-- Code viewer -->
                            <ColumnDefinition Width="3"/>                     <!-- Splitter -->
                            <ColumnDefinition Width="*" MinWidth="120"/>    <!-- File tree -->
                        </Grid.ColumnDefinitions>

                        <!-- File Tree -->
                        <Border Grid.Column="2" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1,0,0,0">
                            <Grid>
                                <!-- Loading text -->
                                <TextBlock x:Name="CodeTreeLoading" Text="Loading file tree..."
                                           FontSize="12" Foreground="#8B949E"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <!-- Tree View -->
                                <TreeView x:Name="CodeTreeView" Background="Transparent" BorderThickness="0"
                                          Foreground="#C9D1D9" FontSize="12" Padding="4"
                                          SelectedItemChanged="CodeTreeView_SelectedItemChanged">
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type local:GitTreeNode}"
                                                                   ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                                <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#C9D1D9"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </HierarchicalDataTemplate>
                                    </TreeView.Resources>
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="Foreground" Value="#C9D1D9"/>
                                            <Setter Property="IsExpanded" Value="False"/>
                                            <Setter Property="Padding" Value="2,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </Grid>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                      Background="#30363D" ResizeDirection="Columns"
                                      Width="3" Cursor="SizeWE"/>

                        <!-- Code Viewer -->
                        <Border Grid.Column="0" Background="#0D1117">
                            <Grid>
                                <!-- File path header -->
                                <Border VerticalAlignment="Top" Padding="12,6" Background="#161B22"
